<Window x:Class="SlimViews.Tooling.Gif"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:Images="clr-namespace:Common.Images;assembly=Common.Images"
        mc:Ignorable="d"
        Title="Gif Editor" Height="450" Width="800" Loaded="Window_Loaded">
    <Grid Background="#FDFDFD">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <ToolBarTray Grid.Row="0" Background="#F5F5F5">
            <ToolBar>
                <Button Command="{Binding OpenCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📂 "/>
                        <TextBlock Text="Open GIF"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding OpenFolderCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📁 "/>
                        <TextBlock Text="Open Folder"/>
                    </StackPanel>
                </Button>
                <Separator />
                <Button Command="{Binding SaveImagesCommand}" IsEnabled="{Binding IsActive}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🖼️ "/>
                        <TextBlock Text="Export Frames"/>
                    </StackPanel>
                </Button>
                <Separator />
                <Button Command="{Binding SaveGifCommand}" IsEnabled="{Binding IsActive}" FontWeight="Bold">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾 "/>
                        <TextBlock Text="Save GIF"/>
                    </StackPanel>
                </Button>
                <Separator />
                <Button Command="{Binding ClearCommand}" Foreground="Firebrick">
                    <TextBlock Text="Clear All" />
                </Button>
            </ToolBar>
        </ToolBarTray>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="120" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#333">
                    <ScrollViewer>
                        <ContentControl Content="{Binding ActiveFrameView}" />
                    </ScrollViewer>
                </Border>

                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Background="#CCC" />

                <Border Grid.Row="2" Background="#EEE" BorderBrush="#CCC" BorderThickness="0,1,0,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <Images:Thumbnails Name="Thumb"
                                       ItemsSource="{Binding Observer}"
                                       ThumbCellSize="100"
                                       ThumbHeight="1"
                                       SelectBox="False"
                                       IsCheckBoxSelected="False"
                                       ImageClicked="Thumb_ImageClicked" />
                    </ScrollViewer>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#DDD" />

            <ScrollViewer Grid.Column="2" Padding="15">
                <StackPanel>
                    <GroupBox Header="Frame Timing">
                        <StackPanel Margin="5">
                            <DockPanel>
                                <TextBlock Text="Delay (ms):" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding CurrentDelay, UpdateSourceTrigger=PropertyChanged}" Margin="10,0,0,0"/>
                            </DockPanel>

                            <Button Content="Save Current Frame" 
                                Command="{Binding SaveCurrentFrameCommand}" 
                                IsEnabled="{Binding IsActive}" 
                                Margin="0,10,0,0"/>

                                            <Button Content="Apply to All" 
                                Command="{Binding SetAllDelayCommand}" 
                                Margin="0,5,0,0"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <StatusBar Grid.Row="2">
            <TextBlock Text="{Binding Information}" />
        </StatusBar>
    </Grid>
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/SlimViewer;component/Themes/Generic.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
</Window>