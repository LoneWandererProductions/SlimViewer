<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:common="clr-namespace:Common.Dialogs"
    x:Class="Common.Dialogs.FolderBrowser"
    Title="FolderBrowser"
    Topmost="False">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="10" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="320" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Button Content="OK" Grid.Column="1" HorizontalAlignment="Stretch" Grid.Row="1" Margin="0,10,0,10" VerticalAlignment="Stretch"
                Click="BtnOk_Click" />
        <Button Content="Cancel" Grid.Column="3" HorizontalAlignment="Stretch" Grid.Row="1" Margin="0,10,0,10" VerticalAlignment="Stretch"
                Click="BtnCancel_Click" />
        <common:FolderControl Grid.Row="0" Grid.Column="1" x:Name="VFolder" Grid.ColumnSpan="3" />
    </Grid>
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Common.Dialogs;component/Themes/Generic.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
</Window>