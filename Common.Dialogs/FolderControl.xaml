<UserControl x:Class="Common.Dialogs.FolderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
             Height="320"
             Padding="5">

    <Grid>
        <!-- Row/Column Definitions -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Display Path -->
            <RowDefinition Height="5" />
            <RowDefinition Height="Auto" />
            <!-- Path Input -->
            <RowDefinition Height="5" />
            <RowDefinition Height="39*" />
            <!-- Navigation Buttons -->
            <RowDefinition Height="5" />
            <RowDefinition Height="38*" />
            <!-- Shortcut 1 -->
            <RowDefinition Height="5" />
            <RowDefinition Height="39*" />
            <!-- Shortcut 2 -->
            <RowDefinition Height="5" />
            <RowDefinition Height="39*" />
            <!-- Shortcut 3 -->
            <RowDefinition Height="5" />
            <RowDefinition Height="39*" />
            <!-- Shortcut 4 -->
            <RowDefinition Height="5" />
            <RowDefinition Height="39*" />
            <!-- Shortcut 5 -->
            <RowDefinition Height="4*" />
            <!-- Spacer -->
            <RowDefinition />
            <!-- TreeView -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <!-- Buttons Column -->
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="0*" />
            <!-- TreeView Column -->
            <ColumnDefinition Width="54*" />
            <!-- Nav Buttons -->
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="59*" />
            <!-- Explorer Button -->
            <ColumnDefinition Width="5" />
            <!-- Up Buttons -->

            <ColumnDefinition Width="54*" />
        </Grid.ColumnDefinitions>

        <!-- Display and input Path -->
        <Grid Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="6" VerticalAlignment="Center">
            <TextBox x:Name="PathEntry"
                     Text="{Binding LookUp, UpdateSourceTrigger=PropertyChanged}"
                     Padding="2"
                     Visibility="Collapsed"
                     LostFocus="PathEntry_LostFocus" />
            <TextBlock x:Name="PathDisplay"
                       Text="{Binding Paths}"
                       TextTrimming="CharacterEllipsis"
                       Background="White"
                       Padding="5,2"
                       Cursor="IBeam"
                       MouseDown="PathDisplay_MouseDown" />
        </Grid>

        <!-- Navigation Buttons -->
        <Button Content="Up" Grid.Row="2" Grid.Column="7" Command="{Binding UpCommand}" />
        <Button Content="Go" Grid.Row="2" Grid.Column="3" Command="{Binding GoCommand}" />
        <Button Content="Exp" Grid.Row="2" Grid.Column="5" Command="{Binding ExplorerCommand}" />

        <!-- Shortcut Buttons -->
        <Button Content="Desktop" Grid.Row="6" Grid.Column="0" VerticalAlignment="Stretch"
                Command="{Binding DesktopCommand}" />
        <Button Content="Root" Grid.Row="4" Grid.Column="0" VerticalAlignment="Stretch" Command="{Binding RootCommand}" />
        <Button Content="Docs" Grid.Row="8" Grid.Column="0" VerticalAlignment="Stretch" Command="{Binding DocsCommand}" />
        <Button Content="Personal" Grid.Row="10" Grid.Column="0" VerticalAlignment="Stretch"
                Command="{Binding PersonalCommand}" />
        <Button Content="Pictures" Grid.Row="12" Grid.Column="0" VerticalAlignment="Stretch"
                Command="{Binding PicturesCommand}" />
        <Button Content="Folder" Grid.Row="14" Grid.Column="0" VerticalAlignment="Stretch"
                Command="{Binding CreateFolderCommand}" />

        <!-- TreeView -->
        <TreeView ItemsSource="{Binding FolderItems}" Grid.Row="6" Grid.Column="2" Grid.RowSpan="9"
                  Grid.ColumnSpan="6">
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                </Style>
            </TreeView.ItemContainerStyle>
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal">
                        <Rectangle Width="16" Height="16" Fill="LightGray" Margin="0,0,5,0" />
                        <TextBlock Text="{Binding Header}" />
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Common.Dialogs;component/Themes/Generic.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
</UserControl>